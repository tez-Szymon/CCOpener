{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ccopener",
  "title": "CCOpener",
  "description": "Open Claude Code in projects configured in CCOpener",
  "icon": "icon.png",
  "access": "private",
  "author": "YOUR_RAYCAST_USERNAME",
  "categories": [
    "Developer Tools",
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "open-project",
      "title": "Open Claude Code Project",
      "subtitle": "CCOpener",
      "description": "Search CCOpener projects and launch Claude Code in Terminal",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.17"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "^22.1.0",
    "@types/react": "^19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "react": "^18.3.1",
    "typescript": "^5.4.5"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint"
  },
  "platforms": [
    "macOS"
  ]
}
